PORT=5000
CLIENT_URL=http://localhost:5173
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/hiretrack"
JWT_SECRET="change-this-secret"

# Optional: real emails. Without these, Nodemailer uses JSON preview mode.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="HireTrack <your-email@gmail.com>"

# Optional: AI features. Without this, backend returns safe fallback text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Telegram bot notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
