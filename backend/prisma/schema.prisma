generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

enum HireApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  HIRED
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String
  role             Role              @default(CANDIDATE)
  jobs             Job[]             @relation("JobRecruiter")
  candidate        Candidate?
  applications     JobApplication[]
  activityLogs     ActivityLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Job {
  id            String            @id @default(uuid())
  title         String
  description   String?           @db.Text
  department    String?
  location      String?
  status        JobStatus         @default(OPEN)
  salaryMin     Int?
  salaryMax     Int?
  skills        String?           @db.Text
  recruiterId   String
  recruiter     User              @relation("JobRecruiter", fields: [recruiterId], references: [id], onDelete: Cascade)
  applications  HireApplication[]
  activityLogs  ActivityLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Candidate {
  id            String            @id @default(uuid())
  userId        String?           @unique
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  name          String
  email         String            @unique
  phone         String?
  resume        String?           @db.Text
  skills        String?           @db.Text
  applications  HireApplication[]
  activityLogs  ActivityLog[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model HireApplication {
  id            String                @id @default(uuid())
  jobId         String
  candidateId   String
  status        HireApplicationStatus @default(APPLIED)
  coverLetter   String?               @db.Text
  interviewAt   DateTime?
  notes         String?               @db.Text
  job           Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate     Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  activityLogs  ActivityLog[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([jobId, candidateId])
  @@map("hire_applications")
}

model JobApplication {
  id            String        @id @default(uuid())
  companyName   String
  positionTitle String
  status        String        @default("Wishlist")
  location      String?
  salaryMin     Int?
  salaryMax     Int?
  jobLink       String?
  notes         String?       @db.Text
  priority      String        @default("Medium")
  appliedDate   DateTime?
  nextStepDate  DateTime?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityLogs  ActivityLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model ActivityLog {
  id                 String           @id @default(uuid())
  action             String
  details            String?          @db.Text
  userId             String
  applicationId      String?
  jobId              String?
  candidateId        String?
  hireApplicationId  String?
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  application        JobApplication?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job                Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate          Candidate?       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  hireApplication    HireApplication? @relation(fields: [hireApplicationId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
}
